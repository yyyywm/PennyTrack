# 生产环境必须修改！
BOOKKEEPING_SECRET_KEY=your-super-secret-key-here

# MySQL 连接串（Docker 内使用 db 作为主机名）
# 本地开发：mysql+pymysql://bookkeeping:bookkeeping@localhost:3306/bookkeeping
# Docker Compose：mysql+pymysql://bookkeeping:bookkeeping@db:3306/bookkeeping
BOOKKEEPING_DATABASE_URL=mysql+pymysql://bookkeeping:bookkeeping@db:3306/bookkeeping
