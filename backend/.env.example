# 生产环境必须修改！建议使用 `python -c "import secrets;print(secrets.token_urlsafe(48))"` 生成
BOOKKEEPING_SECRET_KEY=your-super-secret-key-here

# MySQL 连接串（必填，本工程不再支持 SQLite 回退）
#
# 注意：当前 docker-compose.yml 中 **没有** 内置 db 服务，应用会连接你在此处填写的
# MySQL 实例。请填一个真实可达的 MySQL 地址，例如：
#   - 远端云数据库：mysql+pymysql://user:password@1.2.3.4:3306/bookkeeping
#   - 本机宿主 MySQL（Linux/Mac）：mysql+pymysql://user:password@host.docker.internal:3306/bookkeeping
#
# 如果将来在 docker-compose.yml 中新增了名为 db 的 MySQL 服务，
# 容器互联时主机名才能写成 db，例如：
#   mysql+pymysql://bookkeeping:bookkeeping@db:3306/bookkeeping
BOOKKEEPING_DATABASE_URL=mysql+pymysql://user:password@host:3306/bookkeeping
